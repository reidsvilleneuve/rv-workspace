Plug 'tpope/vim-commentary'
Plug 'tpope/vim-surround'
Plug 'michaeljsmith/vim-indent-object'
packadd matchit

"Highlight search terms
set hlsearch

"Search while typing in search query
set incsearch

"Clear last search highlighting
nnoremap <Space> :noh<cr>
nnoremap g<Space> :noh<cr>

"vim-surround extension
" set surround

"Quicker window movement
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-h> <C-w>h
nnoremap <C-l> <C-w>l

"Quick yanks to system clipboard
nnoremap Y "+y
nnoremap YY ^"+y$
vnoremap Y "+y

"Paste from system clipboard
nnoremap \P "+P
nnoremap \p "+p
vnoremap \p "+p

" Newline-ify a ', '-separated list
nnoremap \,, :s/, /,\r/g<CR>='.:noh<CR>

" Quick macros with Q
nnoremap Q @q
